<Page x:Class="FileOrganizer.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FileOrganizer.Pages"
      mc:Ignorable="d" 
      MinWidth="450" MinHeight="130"
      Title="MainPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="15"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="1" Margin="20 0 40 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                        Background="White"
                        CornerRadius="8"
                        BorderBrush="#DDE1E6"
                        BorderThickness="1"
                        Padding="12,8"
                        Height="35"
                        VerticalAlignment="Center">
                <TextBlock x:Name="FilePathTxt"
                               Text="Выберите папку..."
                               Foreground="#6C757D"
                               FontSize="14"
                               FontFamily="Segoe UI"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"/>
            </Border>

            <Button x:Name="SearchPath"
                        Grid.Column="1"
                        Width="38"
                        Height="38"
                        Margin="10,0,5,0"
                        Style="{StaticResource FolderButton}"
                        ToolTip="Выбрать папку"
                        Cursor="Hand"
                        Click="SearchPath_Click">
                <Viewbox Width="20" Height="20">
                    <Canvas Width="24" Height="24">
                        <Path Fill="#6C757D"
                                  Data="M22,4H14L12,2H6A2,2 0 0,0 4,4V20A2,2 0 0,0 6,22H22A2,2 0 0,0 24,20V6A2,2 0 0,0 22,4Z"/>
                    </Canvas>
                </Viewbox>
            </Button>
        </Grid>
        <Button x:Name="ButSetting"
            HorizontalAlignment="Right"
            VerticalAlignment="Top"
            Grid.Row="0"
            Width="30"
            Height="30"
            FontSize="22"
            Style="{StaticResource FolderButton}"
            ToolTip="Настройки"
            Cursor="Hand"
            Click="ButSetting_Click"
            Content="⚙️"/>
        <Button x:Name="Perform"
                    Grid.Row="3"
                    HorizontalAlignment="Center"
                    Width="140"
                    Height="30"
                    Style="{StaticResource ExecuteButton}"
                    Content="Выполнить"
                    Cursor="Hand"
                    Click="Perform_Click"/>
    </Grid>
</Page>
